{
  "multipart": [
    {
      "when": {
        "shape": "bottom|single"
      },
      "apply": {
        "model": "repackaged:block/package_shelf/single"
      }
    },
    {
      "when": {
        "shape": "bottom|middle|top"
      },
      "apply": {
        "model": "repackaged:block/package_shelf/middle"
      }
    },
    {
      "when": {
        "shape": "top"
      },
      "apply": {
        "model": "repackaged:block/package_shelf/top"
      }
    },
    {
      "when": {
        "AND": [
          {"shape": "bottom|single"},
          {"facing": "north"}
        ]
      },
      "apply": {
        "model": "repackaged:block/package_shelf/connector",
        "y": 0
      }
    }
  ]
}